---
import Base from "@/layouts/Base.astro";
import HeroSection from "@/layouts/components/HeroSection.astro";
import SectionPreview from "@/layouts/components/SectionPreview.astro";
import ExperienceCard from "@/layouts/components/ExperienceCard.astro";
import ProjectCard from "@/layouts/components/ProjectCard.astro";
import CertificationBadge from "@/layouts/components/CertificationBadge.astro";
import TalkCard from "@/layouts/components/TalkCard.astro";
import { getCollection } from "astro:content";

// Hero section data
const heroData = {
  name: "Arsy Opraza Akma",
  title: "Engineer | Public Speaker | Mentor",
  tagline:
    "I am a Software Engineer specializing in Backend and Cloud technologies. With a passion for both building systems and building communities, I operate at the intersection of technical execution and developer education.",
  image: "/images/profile.webp",
};

// Fetch experiences sorted by order ascending, display first 3
const allExperiences = await getCollection("experiences");
const sortedExperiences = allExperiences.sort(
  (a, b) => a.data.order - b.data.order,
);
const displayedExperiences = sortedExperiences.slice(0, 3);

// Fetch projects filtered by featured: true, display up to 4
const allProjects = await getCollection("projects");
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .slice(0, 4);

// Fetch all certifications
const allCertifications = await getCollection("certifications");

// Fetch talks sorted by date descending (undated last), display first 4
const allTalks = await getCollection("talks");
const sortedTalks = allTalks.sort((a, b) => {
  if (!a.data.date && !b.data.date) return 0;
  if (!a.data.date) return 1;
  if (!b.data.date) return -1;
  return b.data.date.getTime() - a.data.date.getTime();
});
const displayedTalks = sortedTalks.slice(0, 4);
---

<Base
  title="Home"
  meta_title="Arsy Opraza - Personal Website"
  description="Portfolio of Arsy Opraza Akma — Software Engineer specializing in Backend and Cloud technologies, speaker, and educator."
  image="/images/profile.webp"
>
  <HeroSection
    name={heroData.name}
    title={heroData.title}
    tagline={heroData.tagline}
    image={heroData.image}
  />

  {displayedExperiences.length > 0 && (
    <section class="relative bg-theme-light/50">
      <div class="container">
        <SectionPreview
          title="Experiences"
          viewAllUrl="/experiences"
          showViewAll={allExperiences.length > 3}
        >
          <!-- Timeline line for desktop -->
          <div class="relative md:pl-6 md:border-l-2 md:border-primary/20">
            <div class="grid gap-5">
              {displayedExperiences.map((exp) => (
                <ExperienceCard
                  icon={exp.data.icon}
                  title={exp.data.title}
                  company={exp.data.company}
                  duration={exp.data.duration}
                  description={exp.data.description}
                />
              ))}
            </div>
          </div>
        </SectionPreview>
      </div>
    </section>
  )}

  {displayedTalks.length > 0 && (
    <section class="relative">
      <div class="container">
        <SectionPreview
          title="Talks"
          viewAllUrl="/talks"
          showViewAll={allTalks.length > 4}
        >
          <div class="grid gap-6 sm:grid-cols-2">
            {displayedTalks.map((talk) => (
              <TalkCard
                title={talk.data.title}
                event_name={talk.data.event_name}
                description={talk.data.description}
                image={talk.data.image}
                date={talk.data.date}
                slides_url={talk.data.slides_url}
                video_url={talk.data.video_url}
              />
            ))}
          </div>
        </SectionPreview>
      </div>
    </section>
  )}

  {featuredProjects.length > 0 && (
    <section class="relative">
      <div class="container">
        <SectionPreview
          title="Projects"
          viewAllUrl="/projects"
          showViewAll={allProjects.filter((p) => p.data.featured).length > 4}
        >
          <div class="grid gap-6 sm:grid-cols-2">
            {featuredProjects.map((project) => (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                link={project.data.link}
                technologies={project.data.technologies}
              />
            ))}
          </div>
        </SectionPreview>
      </div>
    </section>
  )}

  {allCertifications.length > 0 && (
    <section class="relative bg-theme-light/50">
      <div class="container">
        <SectionPreview
          title="Certifications"
          viewAllUrl="/certifications"
          showViewAll={false}
        >
          <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-4">
            {allCertifications.map((cert) => (
              <CertificationBadge
                title={cert.data.title}
                icon={cert.data.icon}
                organization={cert.data.organization}
                credential_url={cert.data.credential_url}
              />
            ))}
          </div>
        </SectionPreview>
      </div>
    </section>
  )}
</Base>
