---
interface Props {
  icon: string;
  title: string;
  company: string;
  duration: string;
  description?: string;
}

const { icon, title, company, duration, description } = Astro.props;

const truncatedDescription =
  description && description.length > 500
    ? description.slice(0, 500)
    : description;
---

<article class="group relative flex gap-5 rounded-2xl border border-border/60 bg-white p-5 transition-all duration-300 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-0.5">
  <!-- Timeline dot (visible on larger screens) -->
  <div class="absolute -left-[9px] top-7 hidden h-4 w-4 rounded-full border-[3px] border-primary bg-white md:block"></div>

  <!-- Company logo -->
  <div class="flex-shrink-0">
    <div class="flex h-14 w-14 items-center justify-center overflow-hidden rounded-xl bg-theme-light p-2 shadow-sm transition-shadow duration-300 group-hover:shadow-md">
      <img
        src={icon}
        alt={`${company} logo`}
        width="48"
        height="48"
        class="h-full w-full rounded-lg object-contain"
        onerror={`this.style.display='none';this.nextElementSibling.style.display='flex';`}
      />
      <span
        class="hidden h-full w-full items-center justify-center text-center text-xs font-bold text-primary"
        aria-hidden="true"
      >
        {company.slice(0, 2).toUpperCase()}
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="flex flex-col min-w-0">
    <div class="flex flex-wrap items-center gap-2 mb-1">
      <h3 class="text-lg font-bold text-dark">{title}</h3>
    </div>
    <p class="text-sm font-medium text-primary">{company}</p>
    <p class="mt-0.5 text-xs font-medium text-light">{duration}</p>
    {truncatedDescription && (
      <p class="mt-3 text-sm leading-relaxed text-text">{truncatedDescription}</p>
    )}
  </div>
</article>
