---
import { Image } from "astro:assets";

interface Props {
  title: string;
  event_name: string;
  description: string;
  image: string;
  date?: Date;
  slides_url?: string;
  video_url?: string;
}

const { title, event_name, description, image, date, slides_url, video_url } =
  Astro.props;

const formatDate = (d: Date): string => {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
};

const truncatedDescription =
  description.length > 200 ? description.slice(0, 200) + "…" : description;
---

<article class="group relative h-full overflow-hidden rounded-2xl border border-border/60 bg-white transition-all duration-300 hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 hover:-translate-y-1">
  <!-- Image with overlay -->
  <div class="relative h-52 overflow-hidden">
    <Image
      src={image}
      alt={`${event_name} event`}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      width={400}
      height={208}
      loading="lazy"
      format="webp"
    />
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-dark/60 via-dark/20 to-transparent"></div>
    <!-- Event name badge -->
    <div class="absolute bottom-3 left-4">
      <span class="inline-flex items-center rounded-full bg-white/90 backdrop-blur-sm px-3 py-1 text-xs font-semibold text-dark shadow-sm">
        {event_name}
      </span>
    </div>
    <!-- Date badge -->
    {date && (
      <div class="absolute top-3 right-3">
        <span class="inline-flex items-center rounded-full bg-primary/90 backdrop-blur-sm px-3 py-1 text-xs font-semibold text-white">
          {formatDate(date)}
        </span>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-5">
    <h3 class="text-lg font-bold text-dark mb-2 line-clamp-2 group-hover:text-primary transition-colors duration-300">
      {title}
    </h3>
    <p class="text-sm leading-relaxed text-text mb-4">{truncatedDescription}</p>

    {(slides_url || video_url) && (
      <div class="flex flex-wrap gap-2">
        {slides_url && (
          <a
            href={slides_url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 min-h-[44px] min-w-[44px] rounded-full border border-primary/20 bg-primary/5 px-4 py-2 text-xs font-semibold text-primary transition-all duration-300 hover:bg-primary hover:text-white focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Slides
          </a>
        )}
        {video_url && (
          <a
            href={video_url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 min-h-[44px] min-w-[44px] rounded-full border border-primary/20 bg-primary/5 px-4 py-2 text-xs font-semibold text-primary transition-all duration-300 hover:bg-primary hover:text-white focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Video
          </a>
        )}
      </div>
    )}
  </div>
</article>
