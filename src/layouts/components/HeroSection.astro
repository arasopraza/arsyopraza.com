---
import { Image } from "astro:assets";
import social from "@/config/social.json";

export interface Props {
  name: string;
  title: string;
  tagline: string;
  image: string;
}

const { name, title, tagline, image } = Astro.props;

const ctaLinks = [
  { label: "About", href: "/about" },
  { label: "Speaker Kit", href: "/speaker" },
  { label: "Talks", href: "/talks" },
  { label: "Blog", href: "/blog" },
];

const socialLinks = [
  { name: "GitHub", url: social.github, icon: "github" },
  { name: "LinkedIn", url: social.linkedin, icon: "linkedin" },
  { name: "Twitter", url: social.twitter, icon: "twitter" },
  { name: "YouTube", url: social.youtube, icon: "youtube" },
  { name: "TikTok", url: social.tiktok, icon: "tiktok" },
].filter((link) => link.url);
---

<section class="hero-section relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-3xl translate-x-1/3 -translate-y-1/3"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-primary/5 rounded-full blur-3xl -translate-x-1/3 translate-y-1/3"></div>
  </div>

  <div class="container py-16 md:py-24">
    <div class="flex flex-col-reverse items-center gap-10 md:flex-row md:gap-16">
      <!-- Text content -->
      <div class="flex-1 text-center md:text-left">
        <h1 class="mb-3 text-4xl font-bold text-dark md:text-5xl lg:text-6xl animate-fade-in-up">
          {name}
        </h1>
        <p class="mb-4 text-xl font-semibold text-primary md:text-2xl animate-fade-in-up animation-delay-100">
          {title}
        </p>
        <p class="mb-8 max-w-lg text-lg leading-relaxed text-text animate-fade-in-up animation-delay-200 mx-auto md:mx-0">
          {tagline}
        </p>

        <!-- Primary CTAs -->
        <div class="mb-4 flex flex-wrap items-center justify-center gap-3 md:justify-start animate-fade-in-up animation-delay-300">
          <a
            href="mailto:talkwith@arsyopraza.com"
            class="inline-flex items-center gap-2 rounded-full bg-primary px-8 py-3 min-h-[44px] text-base font-semibold text-white shadow-lg shadow-primary/25 transition-all duration-300 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Get In Touch
          </a>
          <a
            href="/resume-arsy-opraza.pdf"
            download
            class="inline-flex items-center gap-2 rounded-full border border-border bg-white px-6 py-3 min-h-[44px] text-base font-semibold text-dark shadow-sm transition-all duration-300 hover:border-primary hover:text-primary hover:shadow-md hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download CV
          </a>
        </div>

        <!-- Social media links -->
        <div class="mb-6 flex items-center justify-center gap-3 md:justify-start animate-fade-in-up animation-delay-350">
          {socialLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.name}
              class="inline-flex items-center justify-center h-10 w-10 rounded-full border border-border bg-white text-dark/70 shadow-sm transition-all duration-300 hover:border-primary hover:text-primary hover:shadow-md hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
            >
              {link.icon === "github" && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              )}
              {link.icon === "linkedin" && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              )}
              {link.icon === "twitter" && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              )}
              {link.icon === "youtube" && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              )}
              {link.icon === "tiktok" && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                </svg>
              )}
            </a>
          ))}
        </div>

        <!-- Section navigation pills -->
        <div class="flex flex-wrap justify-center gap-2 md:justify-start animate-fade-in-up animation-delay-400">
          {ctaLinks.map((link) => (
            <a
              href={link.href}
              class="inline-flex items-center rounded-full border border-border bg-white px-4 py-2 min-h-[44px] min-w-[44px] text-sm font-medium text-dark shadow-sm transition-all duration-300 hover:border-primary hover:text-primary hover:shadow-md hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Profile image -->
      <div class="flex-shrink-0 animate-fade-in">
        <div class="relative">
          <!-- Decorative ring -->
          <div class="absolute -inset-3 rounded-full bg-gradient-to-br from-primary/20 to-primary/5 blur-sm"></div>
          <div class="relative h-[250px] w-[250px] md:h-[320px] md:w-[320px] overflow-hidden rounded-full border-4 border-white shadow-2xl">
            {image && (
              <Image
                src={image}
                width={320}
                height={320}
                alt={`Profile photo of ${name}`}
                class="h-full w-full object-cover"
                loading="eager"
                fetchpriority="high"
              />
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.6s ease-out both;
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.6s ease-out both;
  }

  .animation-delay-100 {
    animation-delay: 0.1s;
  }

  .animation-delay-200 {
    animation-delay: 0.2s;
  }

  .animation-delay-300 {
    animation-delay: 0.3s;
  }

  .animation-delay-350 {
    animation-delay: 0.35s;
  }

  .animation-delay-400 {
    animation-delay: 0.4s;
  }
</style>
