---
interface Props {
  title: string;
  viewAllUrl: string;
  showViewAll: boolean;
  subtitle?: string;
}

const { title, viewAllUrl, showViewAll, subtitle } = Astro.props;
const sectionId = title.toLowerCase();
---

<section id={sectionId} class="py-16">
  <div class="mb-10">
    <!-- Section header with decorative accent -->
    <div class="flex items-end justify-between gap-4">
      <div>
        <div class="mb-2 flex items-center gap-3">
        </div>
        <h2 class="text-3xl font-bold text-dark md:text-4xl">{title}</h2>
        {subtitle && (
          <p class="mt-2 text-text">{subtitle}</p>
        )}
      </div>
      {showViewAll && (
        <a
          href={viewAllUrl}
          class="group inline-flex items-center gap-1 min-h-[44px] min-w-[44px] rounded-full border border-border bg-white px-5 py-2 text-sm font-medium text-dark shadow-sm transition-all duration-300 hover:border-primary hover:text-primary hover:shadow-md focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
        >
          View All
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      )}
    </div>
  </div>
  <slot />
</section>
