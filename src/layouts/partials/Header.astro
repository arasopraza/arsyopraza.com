---
import Logo from "@/components/Logo.astro";
import menu from "@/config/menu.json";
import { IoSearch } from "react-icons/io5";

export interface NavigationLink {
  name: string;
  url: string;
}

const { main }: { main: NavigationLink[] } = menu;
const currentPath = Astro.url.pathname;

/**
 * Determines if a navigation link should be marked as active.
 * - For anchor links (e.g., /#experiences), mark active when on the homepage.
 * - For regular page links, match the current path.
 */
function isActive(url: string): boolean {
  // Normalize paths by removing trailing slashes for comparison
  const normalizedCurrent = currentPath.replace(/\/$/, "") || "/";

  if (url.startsWith("/#")) {
    // Anchor links are active when on the homepage
    return normalizedCurrent === "" || normalizedCurrent === "/";
  }

  // Regular page links: exact match (normalized)
  const normalizedUrl = url.replace(/\/$/, "") || "/";
  return normalizedCurrent === normalizedUrl;
}
---

<header class="header pt-6">
  <nav class="navbar container" role="navigation" aria-label="Main navigation">
    <!-- logo -->
    <div class="order-0">
      <Logo />
    </div>
    <!-- navbar toggler -->
    <input id="nav-toggle" type="checkbox" class="hidden" />
    <label
      id="show-button"
      for="nav-toggle"
      class="order-2 flex cursor-pointer items-center min-h-[44px] min-w-[44px] justify-center text-black focus-within:ring-2 focus-within:ring-primary md:order-1 md:hidden"
      aria-expanded="false"
      aria-label="Toggle navigation menu"
    >
      <svg class="h-6 fill-current" viewBox="0 0 20 20">
        <title>Menu Open</title>
        <path d="M0 3h20v2H0V3z m0 6h20v2H0V9z m0 6h20v2H0V0z"></path>
      </svg>
    </label>
    <label
      id="hide-button"
      for="nav-toggle"
      class="order-2 hidden cursor-pointer items-center min-h-[44px] min-w-[44px] justify-center text-black focus-within:ring-2 focus-within:ring-primary md:order-1"
      aria-expanded="true"
      aria-label="Toggle navigation menu"
    >
      <svg class="h-6 fill-current" viewBox="0 0 20 20">
        <title>Menu Close</title>
        <polygon
          points="11 9 22 9 22 11 11 11 11 22 9 22 9 11 -2 11 -2 9 9 9 9 -2 11 -2"
          transform="rotate(45 10 10)"></polygon>
      </svg>
    </label>
    <!-- /navbar toggler -->

    <ul
      id="nav-menu"
      class="navbar-nav order-3 hidden w-full md:order-1 md:flex md:w-auto"
    >
      {
        main.map((menu) => (
          <li class="nav-item">
            <a
              href={menu.url}
              class:list={[
                "nav-link block focus:outline-none focus:ring-2 focus:ring-primary rounded",
                { "text-primary font-bold border-b-2 border-primary": isActive(menu.url) },
              ]}
              aria-current={isActive(menu.url) ? "page" : undefined}
            >
              {menu.name}
            </a>
          </li>
        ))
      }
    </ul>
    <div class="order-1 ml-auto flex md:order-2 md:ml-0">
      <a
        class="mr-4 inline-flex items-center justify-center cursor-pointer min-h-[44px] min-w-[44px] text-xl text-dark transition hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary rounded md:mr-0"
        href="/search"
        title="Search"
        aria-label="Search"
      >
        <IoSearch />
      </a>
    </div>
  </nav>
</header>
